# Sunucunun dinleyeceği port (varsayılan: 3000)
PORT=3000

# Traefik için domain (örn: video.example.com)
DOMAIN=video.example.com

# İsteğe bağlı API anahtarı — boş bırakılırsa kimlik doğrulama devre dışı
# iOS Kestirmesindeki "X-Api-Key" header değeriyle eşleşmeli
API_KEY=buraya_gizli_bir_anahtar_yaz

# Sistem PATH'inde değilse yt-dlp binary yolunu belirt
# YTDLP_BINARY=/usr/local/bin/yt-dlp

# YouTube bot koruması için Netscape formatında cookie dosyası
# Sunucuda oluştur: yt-dlp --cookies-from-browser chrome --cookies-only --skip-download "https://youtube.com"
# Sonra bu dosyayı buraya yolunu yaz (docker-compose mount eder)
COOKIES_FILE=/path/to/cookies.txt
